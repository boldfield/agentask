# syntax=docker/dockerfile:1
# Agentask WORKER / REVIEWER fleet image — the heavy one.
# It runs `claude -p` (subscription auth via CLAUDE_CODE_OAUTH_TOKEN) against a real build, so it
# carries: claude CLI (Node), git + gh, a general build toolchain (Go, Rust, Python, C), the agentask
# CLI, and the harness. Modeled on the proven `nightshift` image. Built amd64-only for now (the cp
# cluster); arm64 is added later alongside the cross-arch build/test dimension.
ARG GO_VERSION=1.25

# --- Build the agentask CLI (static, same as the server/merger image) ---
FROM --platform=$BUILDPLATFORM golang:${GO_VERSION} AS agentask-builder
ARG TARGETOS TARGETARCH
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
ARG VERSION=dev
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} \
    go build -ldflags "-X main.version=${VERSION}" -o /out/agentask ./cmd/agentask

# --- Runtime: Node base (for claude) + toolchains ---
FROM node:20-slim

# System deps + C/C++ toolchain (covers cgo, native builds, and most "build-essential" tools).
RUN apt-get update && apt-get install -y --no-install-recommends \
      git curl ca-certificates jq build-essential pkg-config cmake clang lld \
      python3 python3-pip python3-venv \
 && rm -rf /var/lib/apt/lists/*

# gh CLI (for clone/push + PR ops in pull_request mode).
RUN curl -fsSL https://cli.github.com/packages/githubcli-archive-keyring.gpg \
      -o /usr/share/keyrings/githubcli-archive-keyring.gpg \
 && echo "deb [arch=$(dpkg --print-architecture) signed-by=/usr/share/keyrings/githubcli-archive-keyring.gpg] https://cli.github.com/packages stable main" \
      > /etc/apt/sources.list.d/github-cli.list \
 && apt-get update && apt-get install -y --no-install-recommends gh \
 && rm -rf /var/lib/apt/lists/*

# Go (for Go tools, incl. agentask itself).
COPY --from=golang:1.25-bookworm /usr/local/go /usr/local/go

# claude CLI (subscription auth comes at runtime via CLAUDE_CODE_OAUTH_TOKEN env).
RUN npm install -g @anthropic-ai/claude-code

# agentask CLI + harness + the shared fleet entrypoint.
COPY --from=agentask-builder /out/agentask /usr/local/bin/agentask
COPY harness/ /harness/
COPY deploy/fleet/fleet-entrypoint.sh /usr/local/bin/fleet-entrypoint.sh
RUN chmod +x /usr/local/bin/fleet-entrypoint.sh /harness/agent.sh

# Non-root agent at uid 1000 (numeric USER so k8s runAsNonRoot can verify it).
RUN useradd -m -u 1000 -o -g 1000 agent
USER 1000
ENV HOME=/home/agent \
    AGENTASK_HOME=/home/agent/.agentask \
    PATH="/usr/local/go/bin:/home/agent/.cargo/bin:${PATH}"

# Rust toolchain (per-user via rustup) — many faictory tools are Rust crates.
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --profile minimal --no-modify-path

ENTRYPOINT ["/usr/local/bin/fleet-entrypoint.sh"]
CMD ["--kind", "implement"]
