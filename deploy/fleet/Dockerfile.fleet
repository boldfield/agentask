# syntax=docker/dockerfile:1
# Agentask WORKER / REVIEWER fleet image — the heavy one.
# It runs `claude -p` (subscription auth via CLAUDE_CODE_OAUTH_TOKEN) against a real build, so it
# carries: claude CLI (Node), git + gh, a general build toolchain (Go, Rust, Python, C), the agentask
# CLI, and the harness. Modeled on the proven `nightshift` image. Built amd64-only for now (the cp
# cluster); arm64 is added later alongside the cross-arch build/test dimension.
ARG GO_VERSION=1.25

# --- Build the agentask CLI (static, same as the server/merger image) ---
FROM --platform=$BUILDPLATFORM golang:${GO_VERSION} AS agentask-builder
ARG TARGETOS TARGETARCH
WORKDIR /src
COPY go.mod go.sum ./
RUN go mod download
COPY . .
ARG VERSION=dev
RUN CGO_ENABLED=0 GOOS=${TARGETOS} GOARCH=${TARGETARCH} \
    go build -ldflags "-X main.version=${VERSION}" -o /out/agentask ./cmd/agentask

# --- Runtime: Node base (for claude) + toolchains ---
FROM node:20-slim

# System deps + C/C++ toolchain (covers cgo, native builds, and most "build-essential" tools).
# libgc-dev = Boehm GC: Sigil-compiled programs + the sigil runtime/e2e tests link `-lgc`, so
# without it any sigil `make check`/`make test` fails at link with "unable to find library -lgc",
# which auto-rejects every sigil review round and escalates the task to the top tier.
RUN apt-get update && apt-get install -y --no-install-recommends \
      git curl ca-certificates jq build-essential pkg-config cmake clang lld \
      libgc-dev \
      python3 python3-pip python3-venv \
 && rm -rf /var/lib/apt/lists/*

# gh CLI (for clone/push + PR ops in pull_request mode). Installed from the release tarball rather
# than the github apt repo: that repo would force a SECOND `apt-get update`, which trips a known
# buildkit GPG-verification flake ("invalid signature") under the docker-container driver. The
# tarball is also arch-clean for the future arm64 build. Latest tag resolved via the redirect.
RUN set -eux; \
    arch="$(dpkg --print-architecture)"; \
    ver="$(curl -fsSLI -o /dev/null -w '%{url_effective}' https://github.com/cli/cli/releases/latest | sed 's#.*/tag/v##')"; \
    curl -fsSL "https://github.com/cli/cli/releases/download/v${ver}/gh_${ver}_linux_${arch}.tar.gz" -o /tmp/gh.tgz; \
    tar -xzf /tmp/gh.tgz -C /tmp; \
    install "/tmp/gh_${ver}_linux_${arch}/bin/gh" /usr/local/bin/gh; \
    rm -rf /tmp/gh*

# Go (for Go tools, incl. agentask itself).
COPY --from=golang:1.25-bookworm /usr/local/go /usr/local/go

# claude CLI (subscription auth comes at runtime via CLAUDE_CODE_OAUTH_TOKEN env).
RUN npm install -g @anthropic-ai/claude-code

# Codex CLI (OpenAI Codex tool).
RUN npm install -g @openai/codex

# agentask CLI + harness + the shared fleet entrypoint.
COPY --from=agentask-builder /out/agentask /usr/local/bin/agentask
COPY harness/ /harness/
COPY deploy/fleet/fleet-entrypoint.sh /usr/local/bin/fleet-entrypoint.sh
RUN chmod +x /usr/local/bin/fleet-entrypoint.sh /harness/agent.sh

# Non-root agent at uid 1000 (numeric USER so k8s runAsNonRoot can verify it).
RUN useradd -m -u 1000 -o -g 1000 agent
USER 1000
ENV HOME=/home/agent \
    AGENTASK_HOME=/home/agent/.agentask \
    PATH="/usr/local/go/bin:/home/agent/.cargo/bin:${PATH}"

# Rust toolchain (per-user via rustup) — many faictory tools are Rust crates.
# rustfmt + clippy are required for sigil's `make check` (and the CI rustfmt gate): the minimal
# profile omits them, so workers can't `cargo fmt`/`clippy` and submit unformatted code that the
# rustfmt CI gate rejects. Install both as components.
RUN curl --proto '=https' --tlsv1.2 -sSf https://sh.rustup.rs | sh -s -- -y --profile minimal --no-modify-path -c rustfmt -c clippy

ENTRYPOINT ["/usr/local/bin/fleet-entrypoint.sh"]
CMD ["--kind", "implement"]
