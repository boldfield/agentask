# EXAMPLE ONLY — do not apply this file.
#
# The AGENTASK_TOKEN secret is created OUT-OF-BAND so a real token never lives in
# git and `kubectl apply -k .` / `kubectl apply -f .` can never clobber it with a
# placeholder. Create it directly with a freshly generated token:
#
#   kubectl -n agentask create secret generic agentask-secret \
#     --from-literal=token="$(openssl rand -hex 32)" \
#     --dry-run=client -o yaml | kubectl apply -f -
#
# The deployment reads it via secretKeyRef (name: agentask-secret, key: token).
# This file is named *.yaml.example precisely so kubectl skips it.
apiVersion: v1
kind: Secret
metadata:
  name: agentask-secret
  namespace: agentask
type: Opaque
stringData:
  token: "REPLACE_ME"
---
# Two more OUT-OF-BAND secrets the deployment references (also never in git):
#
# 1) notify-token — bearer token the in-server notify loop presents to the
#    notifier-proxy (env NOTIFY_TOKEN). Use the SAME value as the proxy's token:
#
#      kubectl -n agentask create secret generic notify-token \
#        --from-literal=NOTIFY_TOKEN="$(kubectl -n notifier-proxy get secret \
#          notifier-proxy-secret -o jsonpath='{.data.token}' | base64 -d)" \
#        --dry-run=client -o yaml | kubectl apply -f -
#
# 2) agentask-forge-tokens — per-owner GitHub tokens the PR-watch reconciler reads
#    (mounted at /etc/fleet, FORGE_TOKENS=/etc/fleet/forge-tokens, key "forge-tokens").
#    Reuse the fleet's existing secret by copying it from the agentask-fleet namespace:
#
#      kubectl -n agentask-fleet get secret agentask-forge-tokens -o json \
#        | jq 'del(.metadata.namespace,.metadata.resourceVersion,.metadata.uid,.metadata.creationTimestamp)' \
#        | kubectl -n agentask apply -f -
