# Agentask fleet config — copy to ~/.agentask/env and fill in. NOT versioned (it holds the token).
# Sourced by agent.sh. The ${VAR:-default} form lets you override any value per-invocation.

# The running Agentask instance + a bearer token.
export AGENTASK_URL="${AGENTASK_URL:-https://agentask.example.com}"
# The token can be a literal, or pulled from wherever you keep it, e.g. a k8s secret:
#   export AGENTASK_TOKEN="$(kubectl get secret -n agentask agentask-secret -o jsonpath='{.data.token}' | base64 -d)"
export AGENTASK_TOKEN="${AGENTASK_TOKEN:-<bearer-token>}"

# Project scope:
#   AGENTASK_PROJECT=<uuid>  -> SINGLE-project: pin a slot to that board + its local checkout
#                               (AGENTASK_REPO). Override per run:
#                                 AGENTASK_PROJECT=<id> AGENTASK_REPO=~/projects/<repo> ./worker-haiku.sh <slot>
#   AGENTASK_PROJECT=all     -> MULTI-project: discover + drain every project with claimable work,
#                               cloning each repo on demand (AGENTASK_REPO is then ignored). e.g.:
#                                 AGENTASK_PROJECT=all ./worker-haiku.sh <slot>
#                               Optionally AGENTASK_PROJECTS=<id,id,…> restricts which boards to touch.
export AGENTASK_PROJECT="${AGENTASK_PROJECT:-<project-uuid-or-all>}"
export AGENTASK_REPO="${AGENTASK_REPO:-$HOME/projects/<repo>}"   # single-project mode only

# Optional: where harness STATE lives (agent ids, worktrees, repo clones). Defaults to ~/.agentask.
# export AGENTASK_HOME="$HOME/.agentask"
